<Window x:Class="FocusShade.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="400"
        Height="340"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="#0e0e0e"
        ResizeMode="NoResize"
        AllowsTransparency="False">
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Historic"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e8e8e8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#c8ff00"/>
            <Setter Property="Background" Value="#1c1c1c"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="SegmentedButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#1c1c1c"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#2a2a2a"/>
                    <Setter Property="Foreground" Value="#c8ff00"/>
                    <Setter Property="BorderBrush" Value="#c8ff00"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PillStyle" TargetType="Border">
            <Setter Property="Background" Value="#1c1c1c"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>
    </Window.Resources>
    <Border Background="#0e0e0e" BorderBrush="#2a2a2a" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- Drag + Close -->
            <Grid Grid.Row="0" Background="#0e0e0e" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Button x:Name="CloseButton" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Content="×" FontSize="14" Foreground="#555" Background="Transparent" BorderThickness="0"
                        Padding="12,0" Cursor="Hand" Click="CloseButton_Click"/>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,0,16,12">
                <StackPanel>
                    <!-- BLUR -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="BLUR" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" FontWeight="600" FontSize="13"  Foreground="#555"/>
                        <TextBlock x:Name="BlurPercent" Grid.Column="1" Style="{StaticResource ValueStyle}" Text="50%" VerticalAlignment="Center"/>
                    </Grid>
                    <Slider x:Name="BlurSlider" Minimum="0" Maximum="100" Value="50" Margin="0,4,0,0" ValueChanged="BlurSlider_ValueChanged"/>

                    <!-- DIM -->
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DIM" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" FontWeight="600" FontSize="13"  Foreground="#555"/>
                        <TextBlock x:Name="DimPercent" Grid.Column="1" Style="{StaticResource ValueStyle}" Text="50%" VerticalAlignment="Center"/>
                    </Grid>
                    <Slider x:Name="DimSlider" Minimum="0" Maximum="100" Value="50" Margin="0,4,0,0" ValueChanged="DimSlider_ValueChanged"/>

                    <!-- SHAKE: segmented OFF · LOW · MED · HIGH -->
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SHAKE" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" FontWeight="600" FontSize="13"  Foreground="#555" Margin="0,0,12,0"/>
                        <UniformGrid Grid.Column="1" Rows="1" Columns="4">
                            <ToggleButton x:Name="ShakeOff" Content="OFF" Style="{StaticResource SegmentedButton}" Checked="ShakeSegment_Checked" Margin="0,0,1,0"/>
                            <ToggleButton x:Name="ShakeLow" Content="LOW" Style="{StaticResource SegmentedButton}" Checked="ShakeSegment_Checked" Margin="0,0,1,0"/>
                            <ToggleButton x:Name="ShakeMed" Content="MED" Style="{StaticResource SegmentedButton}" Checked="ShakeSegment_Checked" Margin="0,0,1,0"/>
                            <ToggleButton x:Name="ShakeHigh" Content="HIGH" Style="{StaticResource SegmentedButton}" Checked="ShakeSegment_Checked"/>
                        </UniformGrid>
                    </Grid>

                    <!-- HOTKEY: pill tags -->
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="HOTKEY" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" FontWeight="600" FontSize="13"  Foreground="#555" Margin="0,0,12,0"/>
                        <Button x:Name="HotkeyPillsButton" Grid.Column="1" Click="HotkeyButton_Click" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left" VerticalContentAlignment="Center">
                            <ItemsControl x:Name="HotkeyPills">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PillStyle}" Margin="0,0,4,0">
                                            <TextBlock Text="{Binding}" Foreground="#e8e8e8" FontSize="11" FontFamily="Consolas"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Button>
                    </Grid>

                    <!-- STARTUP -->
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="STARTUP" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" FontWeight="600" FontSize="13"  Foreground="#555"/>
                        <CheckBox x:Name="StartWithWindowsCheck" Grid.Column="1" Checked="StartWithWindows_Changed" Unchecked="StartWithWindows_Changed"
                                  Foreground="#c8ff00" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom strip: FOCUSSHADE v0.1.0 | power button -->
            <Border Grid.Row="2" Background="#161616" Padding="16,0">
                <Grid>
                    <TextBlock x:Name="VersionText" Text="FOCUSSHADE v0.1.0" VerticalAlignment="Center"
                               Foreground="#555" FontSize="10" FontFamily="Segoe UI" />
                    <ToggleButton x:Name="PowerButton" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Width="28" Height="28" Click="PowerButton_Click" Checked="PowerButton_Changed" Unchecked="PowerButton_Changed"
                                  Background="Transparent" BorderThickness="0" Padding="0">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="border" Background="Transparent">
                                    <Ellipse x:Name="circle" Width="20" Height="20" Stroke="#555" StrokeThickness="2" Fill="Transparent"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="circle" Property="Fill" Value="#c8ff00"/>
                                        <Setter TargetName="circle" Property="Stroke" Value="#c8ff00"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
