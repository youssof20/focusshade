<Window x:Class="FocusShade.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FocusShade Settings"
        Width="400"
        Height="340"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Background="#1a1a1a"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#7C6AF7"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="FocusShade" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
            <TextBlock Text="Stay in the zone" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="FocusShade" VerticalAlignment="Center" Foreground="White"/>
            <CheckBox x:Name="ToggleSwitch" Grid.Column="1" Content="" IsChecked="True" Checked="Toggle_Changed" Unchecked="Toggle_Changed"
                      Style="{StaticResource {x:Type CheckBox}}" Foreground="#7C6AF7"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Blur intensity" VerticalAlignment="Center"/>
            <TextBlock x:Name="BlurPercent" Grid.Column="1" Text="50%" VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>
        <Slider x:Name="BlurSlider" Grid.Row="3" Minimum="0" Maximum="100" Value="50" Margin="0,0,0,16" ValueChanged="BlurSlider_ValueChanged"/>

        <Grid Grid.Row="4" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Dim intensity" VerticalAlignment="Center"/>
            <TextBlock x:Name="DimPercent" Grid.Column="1" Text="50%" VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>
        <Slider x:Name="DimSlider" Grid.Row="5" Minimum="0" Maximum="100" Value="50" Margin="0,0,0,16" ValueChanged="DimSlider_ValueChanged"/>

        <Grid Grid.Row="6" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Shake sensitivity" VerticalAlignment="Center"/>
            <ComboBox x:Name="ShakeCombo" Grid.Column="1" SelectedIndex="2" SelectionChanged="ShakeCombo_SelectionChanged" Background="#2d2d2d" Foreground="White">
                <ComboBoxItem Content="Off"/>
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="7" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Hotkey" VerticalAlignment="Center"/>
            <Button x:Name="HotkeyButton" Grid.Column="1" Content="Ctrl+Shift+F" Padding="12,4" Click="HotkeyButton_Click" Background="#2d2d2d" Foreground="White" BorderThickness="0"/>
        </Grid>

        <CheckBox x:Name="StartWithWindowsCheck" Grid.Row="8" Content="Start with Windows" Foreground="White" Margin="0,4,0,0" Checked="StartWithWindows_Changed" Unchecked="StartWithWindows_Changed"/>

        <TextBlock x:Name="VersionText" Grid.Row="9" Text="Version 1.0.0" FontSize="10" Foreground="#666" Margin="0,12,0,0"/>
    </Grid>
</Window>
