<Window x:Class="FocusShade.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        IsHitTestVisible="False">
    <Grid>
        <Image x:Name="BlurImage" Stretch="Fill" IsHitTestVisible="False"/>
        <Rectangle x:Name="DimLayer" Fill="#80000000" IsHitTestVisible="False"/>
    </Grid>
</Window>
